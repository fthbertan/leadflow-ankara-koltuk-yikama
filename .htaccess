# LeadFlow — Apache/LiteSpeed Güvenlik & Yönlendirme Ayarları
# Cloudflare _headers ve _redirects yerine geçer

# ══════════════════════════════════════
# GENEL AYARLAR
# ══════════════════════════════════════
Options -Indexes
ServerSignature Off
ErrorDocument 404 /404.html

# UTF-8 karakter seti
AddDefaultCharset UTF-8

# ══════════════════════════════════════
# GÜVENLİK BAŞLIKLARI
# ══════════════════════════════════════
<IfModule mod_headers.c>
    # Tüm site için
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://maps.google.com https://maps.gstatic.com https://*.googleapis.com https://www.google-analytics.com; frame-src 'self' https://maps.google.com https://www.google.com; connect-src 'self' https://www.google-analytics.com https://www.googletagmanager.com"
</IfModule>

# ══════════════════════════════════════
# ADMIN KLASÖRÜ — Ek güvenlik
# ══════════════════════════════════════
<IfModule mod_headers.c>
    <If "%{REQUEST_URI} =~ m#^/admin/#">
        Header always set X-Frame-Options "DENY"
        Header always set Referrer-Policy "no-referrer"
    </If>
</IfModule>

# ══════════════════════════════════════
# API KLASÖRÜ — CORS
# ══════════════════════════════════════
<IfModule mod_headers.c>
    <If "%{REQUEST_URI} =~ m#^/api/#">
        Header always set Access-Control-Allow-Origin "*"
        Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Header always set Access-Control-Allow-Headers "Content-Type, Authorization"
    </If>
</IfModule>

# ══════════════════════════════════════
# HASSAS DOSYALARI KORU
# ══════════════════════════════════════

# config.php'ye dışarıdan erişimi engelle
<Files "config.php">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>

# schema.sql'e dışarıdan erişimi engelle
<Files "schema.sql">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>

# .env dosyasını koru
<Files ".env">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>

# ══════════════════════════════════════
# DATA KLASÖRÜ — Dizin listelemeyi engelle
# ══════════════════════════════════════
<IfModule mod_rewrite.c>
    RewriteEngine On

    # www → non-www yönlendirme (domain ekleyince aktif et)
    # RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    # RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

    # HTTPS zorla (hosting SSL sağlıyorsa aktif et)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

    # ── Statik sayfalar (.html uzantısız) ──
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.+)$ $1.html [L]

    # ── SEO Hizmet Sayfaları ──
    # Bu kurallar site üretimi sırasında otomatik eklenir
    # Sektöre özel hizmet ve lokasyon slug'ları site_generator.py tarafından yazılır
    # LEADFLOW_SEO_RULES_START
    # /koltuk-yikama vb. hizmet sayfaları
    RewriteRule ^(koltuk-yikama|sandalye-berjer-yikama|cekyat-kanepe-yikama|yatak-yikama|perde-yikama|yorgan-yikama|leke-koku-giderme|anti-bakteriyel-dezenfeksiyon)$ /seo-service.php?svc=$1 [L,QSA]

    # /eryaman-koltuk-yikama vb. → seo-location.php (ahi-evran gibi tireli slug'lar için non-greedy)
    RewriteRule ^([a-z-]+?)-(koltuk-yikama|sandalye-berjer-yikama|cekyat-kanepe-yikama|yatak-yikama|perde-yikama|yorgan-yikama|leke-koku-giderme|anti-bakteriyel-dezenfeksiyon)$ /seo-location.php?loc=$1&svc=$2 [L,QSA]
    # LEADFLOW_SEO_RULES_END

</IfModule>

# ══════════════════════════════════════
# SIKIŞTIRMA (Performans)
# ══════════════════════════════════════
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ══════════════════════════════════════
# CACHE (Performans)
# ══════════════════════════════════════
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# Cache-Control header'ları (PageSpeed önerisi)
<IfModule mod_headers.c>
    # HTML — her zaman taze (Safari/in-app browser cache fix)
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# .admin-info.json dosyasini koru
<Files ".admin-info.json">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>
